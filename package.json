{
  "name": "prompt-supporter-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "preview": "vite preview",
    "licenses": "npx license-checker --production --json > public/licenses.json && node scripts/generate-licenses.cjs",
    "vite:dev": "npm run licenses && vite",
    "vite:build": "npm run licenses && tsc && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "i18next": "^26.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "license-checker": "^25.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  },
  "volta": {
    "node": "22.16.0"
  }
}
